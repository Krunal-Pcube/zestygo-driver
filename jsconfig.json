{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-native",
    "checkJs": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": "."
  },
  "exclude": [ 
    "node_modules",
    "android",
    "ios",
    "build",
    "dist"
  ],
  "include": [
    "**/*.js",
    "**/*.jsx"
, "src/screens/HomeScreen.jsx", "src/components/homeComponents/homeHeader.tsx"  ]
}
